# factory configuration — copy to `.env` and fill in. The daemon reads these
# from the environment; `.env` is loaded automatically (real env vars win).
# NEVER commit a real `.env` (it holds mail credentials).

# --- Target repository (where PRs are opened) ---------------------------------
FACTORY_REPO_PATH=/home/sarocu/Projects/your-target-repo   # required
FACTORY_BASE_BRANCH=main
FACTORY_BRANCH_PREFIX=factory          # branches look like factory/eng-123-slug
FACTORY_SPECS_DIR=specs                # spec files written under <repo>/specs/

# --- Loop ---------------------------------------------------------------------
FACTORY_POLL_INTERVAL=180              # seconds between polls
# FACTORY_DRY_RUN=1                    # log intended actions, mutate nothing

# --- Linear (used via the Linear MCP server through `claude -p`) ---------------
FACTORY_LINEAR_TEAM=ENG                # team key; required to poll Linear
FACTORY_LINEAR_TRIGGER_STATE=Todo      # issues in this state get picked up
FACTORY_LINEAR_INPROGRESS_STATE=In Progress
FACTORY_LINEAR_REVIEW_STATE=In Review
# FACTORY_LINEAR_BLOCKED_STATE=Blocked # if set, blocked runs move here

# --- Inbox monitor (IMAP) — second trigger source -----------------------------
FACTORY_IMAP_HOST=imap.gmail.com
FACTORY_IMAP_PORT=993                  # SSL
FACTORY_IMAP_USER=factory@example.com
FACTORY_IMAP_PASS=app-password-here
FACTORY_IMAP_FOLDER=INBOX
# FACTORY_IMAP_ALLOWED_SENDERS=sam@sarocu.com,boss@example.com  # empty = any

# --- Notifications (SMTP) -----------------------------------------------------
FACTORY_SMTP_HOST=smtp.gmail.com
FACTORY_SMTP_PORT=587                  # STARTTLS
FACTORY_SMTP_STARTTLS=1
FACTORY_SMTP_USER=factory@example.com
FACTORY_SMTP_PASS=app-password-here
FACTORY_SMTP_FROM=factory@example.com
FACTORY_NOTIFY_TO=sam@sarocu.com

# --- Binaries / agent ---------------------------------------------------------
FACTORY_CLAUDE_BIN=claude
FACTORY_PRINTER_BIN=printer
FACTORY_AGENT_MODEL=opus
FACTORY_PRINTER_MAX_TURNS=40
