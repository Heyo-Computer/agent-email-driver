# factory configuration — copy to `.env` and fill in. The daemon reads these
# from the environment; `.env` is loaded automatically (real env vars win).
# NEVER commit a real `.env` (it holds mail credentials).

# --- Target repository (where PRs are opened) ---------------------------------
FACTORY_REPO_PATH=/home/sarocu/Projects/your-target-repo   # required
FACTORY_BASE_BRANCH=main
FACTORY_BRANCH_PREFIX=factory          # branches look like factory/eng-123-slug
FACTORY_SPECS_DIR=specs                # spec files written under <repo>/specs/

# --- Loop ---------------------------------------------------------------------
FACTORY_POLL_INTERVAL=180              # seconds between polls
# FACTORY_DRY_RUN=1                    # log intended actions, mutate nothing

# --- Linear (used via the Linear MCP server through `claude -p`) ---------------
FACTORY_LINEAR_TEAM=ENG                # team key; required to poll Linear
FACTORY_LINEAR_TRIGGER_STATE=Todo      # issues in this state get picked up
FACTORY_LINEAR_INPROGRESS_STATE=In Progress
FACTORY_LINEAR_REVIEW_STATE=In Review
# FACTORY_LINEAR_BLOCKED_STATE=Blocked # if set, blocked runs move here

# --- Inbox monitor (IMAP) — second trigger source -----------------------------
FACTORY_IMAP_HOST=imap.gmail.com
FACTORY_IMAP_PORT=993                  # SSL
FACTORY_IMAP_USER=factory@example.com
FACTORY_IMAP_PASS=app-password-here
FACTORY_IMAP_FOLDER=INBOX
# --- Email triage (both gates must pass before an email becomes work) ---------
# 1) Sender allowlist. Entries are full addresses or bare domains (@example.com).
#    EMPTY = no email triggers at all (an unset allowlist rejects everything, so
#    the whole inbox can't spawn PRs). Set it to enable email.
# FACTORY_IMAP_ALLOWED_SENDERS=sam@sarocu.com,@example.com
# 2) Explicit directive. The subject or body must contain one of these markers,
#    i.e. the message has to actually ask factory to do something — this stops
#    newsletters / auto-notifications from being turned into PRs.
# FACTORY_IMAP_REQUIRE_DIRECTIVE=1                          # 0 disables this gate
# FACTORY_IMAP_DIRECTIVE_MARKERS=factory:,@factory,hey factory   # default markers

# --- Notifications (SMTP) -----------------------------------------------------
FACTORY_SMTP_HOST=smtp.gmail.com
FACTORY_SMTP_PORT=587                  # STARTTLS
FACTORY_SMTP_STARTTLS=1
FACTORY_SMTP_USER=factory@example.com
FACTORY_SMTP_PASS=app-password-here
FACTORY_SMTP_FROM=factory@example.com
FACTORY_NOTIFY_TO=sam@sarocu.com

# --- Binaries / agent ---------------------------------------------------------
FACTORY_CLAUDE_BIN=claude
FACTORY_PRINTER_BIN=printer
FACTORY_AGENT_MODEL=opus
FACTORY_PRINTER_MAX_TURNS=40

# --- Self-improvement (factory editing its own source via printer) ------------
# A Linear ticket / email whose TITLE starts with FACTORY_SELF_MARKER is routed
# to the self-update path instead of the customer repo. printer edits factory's
# own source, then it is built (compile + import smoke), committed, and factory
# restarts itself via the supervisor (see supervisord.conf).
# FACTORY_SELF_PATH=/home/sarocu/Projects/factory   # defaults to factory's dir
FACTORY_SELF_MARKER=[self]             # title prefix that triggers a self-update
FACTORY_SELF_SPECS_DIR=specs          # self specs live under FACTORY_SELF_PATH
# FACTORY_SELF_PUSH=1                  # also push self changes to origin
FACTORY_SELF_RESTART=1                 # restart after a good self-update (default on)
FACTORY_SUPERVISORCTL_BIN=supervisorctl
# FACTORY_SUPERVISOR_CONF=/home/sarocu/Projects/factory/supervisord.conf  # default
FACTORY_SUPERVISOR_PROGRAM=factory     # [program:NAME] in supervisord.conf
